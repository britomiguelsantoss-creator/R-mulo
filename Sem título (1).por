programa {
  funcao inicio() {
    inteiro ano_nascimento, ano_atual
    escreva("coloque seu ano de nascimento porra")
    leia (ano_nascimento)
    escreva("coloque o ano atual")
    leia (ano_atual)
    ano_nascimento = ano_atual-ano_nascimento
    escreva("a bosta da sua idade"," ",ano_nascimento)
  }
}
